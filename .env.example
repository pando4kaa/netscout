# PostgreSQL (required). Run: docker compose up -d
# Use 127.0.0.1 (not localhost) on Windows — avoids IPv6 timeout with Docker
DATABASE_URL=postgresql://netscout:netscout@127.0.0.1:5432/netscout

# API Keys (optional, for External APIs tab)
# SHODAN_API_KEY=your_key_here          # from https://account.shodan.io
# VIRUSTOTAL_API_KEY=your_key_here     # from https://www.virustotal.com/gui/my-apikey
# ALIENVAULT_OTX_API_KEY=your_key_here # from https://otx.alienvault.com/api (free)
# ABUSEIPDB_API_KEY=your_key_here      # from https://www.abuseipdb.com/account/api (1000/day)
# SECURITYTRAILS_API_KEY=your_key_here # from https://securitytrails.com (50/mo, 2500 for OSINT)
# CERTSPOTTER_API_TOKEN=your_token     # from https://sslmate.com (optional, 100 req/h)
# ZOOMEYE_API_KEY=your_key             # from https://www.zoomeye.org (10k points/mo)
# PHISHTANK_APP_KEY=your_key           # from https://phishtank.org (optional, higher rate limit)
# CRIMINALIP_API_KEY=your_key          # from https://www.criminalip.io (free tier)
# PULSEDIVE_API_KEY=your_key           # from https://pulsedive.com (50/day, 500/mo)
# Censys: Personal Access Token from https://accounts.censys.io/settings/personal-access-tokens
# CENSYS_API_TOKEN=censys_xxxxx_yyyyy

# Neo4j graph database (optional). Use with docker compose.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=netscout

# Redis (optional, for cache and rate limiting)
# REDIS_URL=redis://localhost:6379/0

# Auth (optional; default works for dev)
# JWT_SECRET=your-secret-key-for-production

# Configuration
# DNS_TIMEOUT=5
# HTTP_TIMEOUT=10
# CRTSH_TIMEOUT=60  # crt.sh is slow for large domains (default 60s)
# HTTP_VERIFY_SSL=false  # set to disable SSL cert verification (for targets with self-signed/incomplete chain)
